# Environment Variables — a2a-opencode
#
# Copy this file to .env and fill in the values you need.
# Never commit .env to source control.
#
# Most settings can also be provided via a JSON config file or CLI flags.
# Priority order: defaults < config JSON < environment variables < CLI flags

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Port the A2A HTTP server listens on (default: 3000)
# PORT=3000

# Bind address (default: 0.0.0.0)
# HOSTNAME=0.0.0.0

# Hostname embedded in agent card URLs — set to your machine's IP or domain
# when running behind Docker or a reverse proxy (default: localhost)
# ADVERTISE_HOST=localhost

# ---------------------------------------------------------------------------
# OpenCode
# ---------------------------------------------------------------------------

# URL of the running OpenCode server (default: http://localhost:4096)
# OPENCODE_URL=http://localhost:4096

# LLM model to use — format: provider/model
# Examples: anthropic/claude-sonnet-4-20250514, github-copilot/gpt-4o
# OPENCODE_MODEL=

# OpenCode agent preset (default: OpenCode's built-in default)
# OPENCODE_AGENT=

# Project directory to pass to OpenCode sessions (default: empty)
# WORKSPACE_DIR=/path/to/project

# ---------------------------------------------------------------------------
# Agent Card (overrides config file)
# ---------------------------------------------------------------------------

# AGENT_NAME=My OpenCode Agent
# AGENT_DESCRIPTION=What my agent does

# ---------------------------------------------------------------------------
# Permissions
# ---------------------------------------------------------------------------

# Auto-approve all tool call permissions (default: true)
# Set to "false" to require manual approval
# AUTO_APPROVE=true

# Auto-answer questions from OpenCode (default: true)
# AUTO_ANSWER=true

# ---------------------------------------------------------------------------
# Features
# ---------------------------------------------------------------------------

# Stream artifact chunks in real time (A2A spec mode).
# Set to "true" for streaming clients; leave unset for buffered (Inspector-compatible) mode.
# STREAM_ARTIFACTS=false

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info
