# Environment Variables — a2a-claude
#
# Copy this file to .env and fill in the values you need.
# Never commit .env to source control.
#
# Most settings can also be provided via a JSON config file or CLI flags.
# Priority order: defaults < config JSON < environment variables < CLI flags

# ---------------------------------------------------------------------------
# Anthropic Authentication
# ---------------------------------------------------------------------------

# Anthropic API key — required for Claude Agent SDK access.
# ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------------------
# Workspace
# ---------------------------------------------------------------------------

# Absolute path to the Git repository Claude will operate in.
# Required. Can also be set via --workspace CLI flag or claude.workingDirectory
# in config.json.
# WORKSPACE_DIR=/path/to/your/repo

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------

# Port the A2A HTTP server listens on (default: 3030)
# PORT=3030

# Bind address (default: 0.0.0.0)
# HOSTNAME=0.0.0.0

# Hostname embedded in agent card URLs — set to your machine's IP or domain
# when running behind Docker or a reverse proxy (default: localhost)
# ADVERTISE_HOST=localhost

# ---------------------------------------------------------------------------
# Claude Code
# ---------------------------------------------------------------------------

# LLM model to use (default: determined by Claude Agent SDK)
# Examples: claude-sonnet-5, claude-opus-4-8
# CLAUDE_MODEL=claude-sonnet-5

# ---------------------------------------------------------------------------
# Agent Card (overrides config file)
# ---------------------------------------------------------------------------

# AGENT_NAME=My Claude Agent
# AGENT_DESCRIPTION=What my agent does

# ---------------------------------------------------------------------------
# Features
# ---------------------------------------------------------------------------

# Stream artifact chunks in real time (A2A spec mode).
# Set to "true" for streaming clients; leave unset for buffered (Inspector-compatible) mode.
# STREAM_ARTIFACTS=false

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log level: debug | info | warn | error (default: info)
# LOG_LEVEL=info
