{
  "$schema": "../../schemas/agent-config.schema.json",
  "agentCard": {
    "name": "Antigravity Code Agent",
    "description": "A repository-scoped coding agent backed by Google Antigravity with shell command execution enabled.",
    "version": "0.1.1",
    "skills": [
      {
        "id": "software-engineering",
        "name": "Software Engineering",
        "description": "Analyze, edit, explain code, and run local shell commands in a configured workspace.",
        "tags": ["code", "antigravity", "gemini", "shell"]
      }
    ]
  },
  "server": {
    "port": 3040,
    "hostname": "0.0.0.0",
    "advertiseHost": "localhost"
  },
  "antigravity": {
    "workingDirectory": "${WORKSPACE_DIR}",
    "model": "gemini-3.1-flash-lite",
    "provider": {
      "authMode": "apiKey",
      "apiKey": "${GEMINI_API_KEY}"
    },
    "policies": {
      "mode": "allowAll"
    }
  },
  "features": {
    "streamArtifactChunks": false,
    "emitReasoning": true,
    "emitToolEvents": true,
    "trackUsage": true
  },
  "events": {
    "enabled": true,
    "transport": "a2a"
  }
}
